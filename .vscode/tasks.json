{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "📦 Docker - Container Status",
            "type": "shell",
            "command": "docker ps"
        },
        {
            "label": "📦 Docker - PHP Version",
            "type": "shell",
            "command": "docker exec conn2flow-app bash -c \"php -v\""
        },
        {
            "label": "📦 Docker - Apache Logs > 50 Lines",
            "type": "shell",
            "command": "docker logs conn2flow-app --tail 50",
            "problemMatcher": []
        },
        {
            "label": "📦 Docker - Apache Logs > Real Time",
            "type": "shell",
            "command": "docker logs conn2flow-app --tail 50 --follow"
        },
        {
            "label": "📦 Docker - PHP Logs Truncate",
            "type": "shell",
            "command": "docker exec conn2flow-app bash -c \"truncate -s 0 /var/log/php_errors.log\"",
            "problemMatcher": []
        },
        {
            "label": "📦 Docker - PHP Logs > 50 Lines",
            "type": "shell",
            "command": "docker exec conn2flow-app bash -c \"tail -50 /var/log/php_errors.log\"",
            "problemMatcher": []
        },
        {
            "label": "📦 Docker - PHP Logs > Real Time",
            "type": "shell",
            "command": "docker exec conn2flow-app bash -c \"tail -f /var/log/php_errors.log\""
        },
        {
            "label": "🔧 Installer - GIT Release",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/releases/release-installer.sh ${input:tipo} \"${input:tagMsg}\" \"${input:commitMsg}\""
        },
        {
            "label": "🔧 Installer - Synchronize",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/dev-environment/synchronize-manager-installer.sh checksum"
        },
        {
            "label": "🔧 Installer - Build Local",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/updates/build-local-manager-installer.sh"
        },
        {
            "label": "🔧 Installer - New Local Installation",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/dev-environment/create-new-installation.sh"
        },
        {
            "label": "🛠️ Manager - GIT Release",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/releases/release.sh ${input:tipo} \"${input:tagMsg}\" \"${input:commitMsg}\"",
            "problemMatcher": []
        },
        {
            "label": "🛠️ Manager - GIT Commit",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/commits/commit.sh \"${input:commitMsg}\""
        },
        {
            "label": "🛠️ Manager - Synchronize => Resources - Local",
            "type": "shell",
            "command": "php ./gestor/controladores/agents/arquitetura/atualizacao-dados-recursos.php",
            "problemMatcher": []
        },
        {
            "label": "🛠️ Manager - Synchronize => Database - Test Environment",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/dev-environment/updates-manager-database.sh",
            "problemMatcher": []
        },
        {
            "label": "🛠️ Manager - Synchronize => Files - Test Environment",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/dev-environment/synchronize-manager.sh checksum",
            "problemMatcher": []
        },
        {
            "label": "🛠️ Manager - Build Local",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/updates/build-local-manager.sh"
        },
        {
            "label": "🛠️ Manager - Create Module",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/dev-environment/create-new-module.sh \"${input:moduloID}\""
        },
        {
            "label": "Fix TailwindCSS suggestCanonicalClasses",
            "type": "shell",
            "command": "node ./ai-workspace/pt-br/scripts/utils/fix-tailwind-spacing.js --replace --apply-config --target ${input:target}",
            "problemMatcher": []
        },
        {
            "label": "🛠️ Manager - Update => All - Test Environment",
            "dependsOn": [
                "🛠️ Manager - Synchronize => Resources - Local",
                "🛠️ Manager - Synchronize => Files - Test Environment",
                "🛠️ Manager - Synchronize => Database - Test Environment"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "🧩 Private Plugins - Synchronize Active Plugin",
            "type": "shell",
            "command": "bash ./dev-plugins/plugins/private/scripts/dev/synchronizes.sh checksum"
        },
        {
            "label": "🧩 Private Plugins - Build Local Active Plugin",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/updates/build-local-manager-plugin.sh --type=private"
        },
        {
            "label": "🧩 Private Plugins - Plugin Resources",
            "type": "shell",
            "command": "php ./dev-plugins/plugins/private/scripts/resources/update-data-resources-plugin.php"
        },
        {
            "label": "🧩 Private Plugins - GIT Release",
            "type": "shell",
            "command": "bash ./dev-plugins/plugins/private/scripts/releases/release.sh ${input:tipo} \"${input:tagMsg}\" \"${input:commitMsg}\""
        },
        {
            "label": "🧩 Private Plugins - GIT Commit",
            "type": "shell",
            "command": "bash ./dev-plugins/plugins/private/scripts/commits/commit.sh \"${input:commitMsg}\""
        },
        {
            "label": "🧩 Public Plugins - Synchronize Active Plugin",
            "type": "shell",
            "command": "bash ./dev-plugins/plugins/public/scripts/dev/synchronizes.sh checksum"
        },
        {
            "label": "🧩 Public Plugins - Build Local Active Plugin",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/updates/build-local-manager-plugin.sh"
        },
        {
            "label": "🧩 Public Plugins - Plugin Resources",
            "type": "shell",
            "command": "php ./dev-plugins/plugins/public/scripts/resources/update-data-resources-plugin.php"
        },
        {
            "label": "🧩 Public Plugins - GIT Release",
            "type": "shell",
            "command": "bash ./dev-plugins/plugins/public/scripts/releases/release.sh ${input:tipo} \"${input:tagMsg}\" \"${input:commitMsg}\""
        },
        {
            "label": "🧩 Public Plugins - GIT Commit",
            "type": "shell",
            "command": "bash ./dev-plugins/plugins/public/scripts/commits/commit.sh \"${input:commitMsg}\""
        },
        {
            "label": "🗃️ Projects - Synchronize => Resources - Local",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/projects/update-resource-data.sh"
        },
        {
            "label": "🗃️ Projects - Synchronize => Files -> ID",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/projects/synchronize-project.sh --project ${input:projectID} checksum",
            "problemMatcher": []
        },
        {
            "label": "🗃️ Projects - Deploy Current Project",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/projects/deploy-project-v2.sh",
            "problemMatcher": []
        },
        {
            "label": "🗃️ Projects - Deploy Project -> ID",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/projects/deploy-project-v2.sh --project ${input:projectID}",
            "problemMatcher": []
        },
        {
            "label": "🗃️ Projects - Update Current Project",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/projects/update-system.sh",
            "problemMatcher": []
        },
        {
            "label": "🗃️ Projects - Update Project -> ID",
            "type": "shell",
            "command": "bash ./ai-workspace/en/scripts/projects/update-system.sh --project ${input:projectID}",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "tipo",
            "description": "✔️ Release Type (patch, minor, major) ❔",
            "type": "promptString"
        },
        {
            "id": "tagMsg",
            "description": "🔖 TAG Message ❔",
            "type": "promptString"
        },
        {
            "id": "commitMsg",
            "description": "📦 Commit Message ❔",
            "type": "promptString"
        },
        {
            "id": "moduloID",
            "description": "📦 Module ID ❔",
            "type": "promptString"
        },
        {
            "id": "projectID",
            "description": "📦 Project ID ❔",
            "type": "promptString"
        },
        {
            "id": "target",
            "description": "Target folder for the fix script (relative to workspace root). Ex: ../conn2flow-site",
            "type": "promptString",
            "default": "../conn2flow-site"
        }
    ]
}